{
  "expo": {
    "name": "XinXamApp",
    "slug": "XinXamApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "xinxamapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.cuong.xinxam",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a636c"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a636c"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e0aa649a-75af-40e7-8e48-cbf225a76f60"
      }
    }
  }
}
